# Copia este archivo como .env.local y llena con las llaves de tu proyecto Supabase.
# .env.local NUNCA se sube a GitHub (está en .gitignore).
# Estas mismas 3 variables van en Netlify: Site configuration → Environment variables.

# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...la_anon...

# Settings → API → Project API keys → service_role (SECRETA)
# Solo se usa en scripts de servidor (ej. scripts/seed_perfiles.ts). Jamás en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...la_service_role...

# Fase 3 (notificaciones por correo). Aún no se usa.
# RESEND_API_KEY=re_...
